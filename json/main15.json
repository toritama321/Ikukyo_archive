  {
    "id": "main15-3",
    "updateat": "2026/5/15",
    "name": "メア・マーヴル",
    "kana": "めあ・まーゔる",
    "owner": "えびしぐれ",
    "originalCharacter": "ドレミー・スイート",
    "wikiurl": "https://dic.pixiv.net/a/%E3%83%A1%E3%82%A2%E3%83%BB%E3%83%9E%E3%83%BC%E3%83%B4%E3%83%AB",
    "basic": {
      "gender": "女",
      "age": "不明",
      "birthday": "6月10日",
      "height": "150cm",
      "weight": "0？（実体無し）"
    },
    "personal": {
      "job": "",
      "hobbiesAndSkills": "夢集め",
      "firstPerson": "私",
      "secondPerson": "あなた",
      "thirdPerson": "",
      "likes": "夢",
      "dislikes": "身分の高い人、火"
    },
    "world": {
      "species": "妖怪(獏？)",
      "alias": [
        "夢の案内者"
      ],
      "abilities": "夢へ導く程度の能力、眠りへ誘う程度の能力",
      "mainLocations": [
        "夢の世界",
        "華胥通路"
      ],
      "dangerLevel": "中",
      "humanFriendliness": "低",
      "songs": [
        "夢間牢獄 〜eternal dream"
      ]
    },
    "details": [
      {
        "title": "容姿",
        "body": [
          "円錐型のナイトキャップを浅めに被っているため、金髪は腰の辺りまである程長いのだが分かりにくい。黒いノースリーブのハイネック、薄紫色と薄桃色の飾りがついたケープとスカートを着用している。手足には包帯が巻かれている。"
        ]
      },
      {
        "title": "性格",
        "body": [
          "おっとりしているが、どこか影がある。勘が鋭く、彼女の前で隠し事をするのはかなり難しい。表には出さないが、排他的で傲慢な月の民を快く思っていないため異変時に月の民に協力する事を渋っていた。",
          "秘密裏にある約束をしているらしく、初月には強くあたらない。"
        ]
      },
      {
        "title": "能力",
        "body": [
          "#### 夢へ導く程度の能力",
          "対象の見るべき夢へ導く能力。間違うことなく正確な夢へ導けるが、彼女の意思次第では本来見るべきではない夢を見せることも出来る。",
          "#### 眠りへ誘う程度の能力",
          "文字通り対象を眠らせる能力。眠りの深さはある程度操作できるらしい。"
        ]
      },
      {
        "title": "華胥通路",
        "body": [
          "夢の世界を繋ぐ通路であり、異空郷の多くの人妖が眠る夜はここを通り見回りを行っている。かなり広く、幾つにも分かれているため、妖精に手伝わせることも多い。"
        ]
      },
      {
        "title": "その他",
        "body": [
          "かつて人間だった彼女は火事により肉体の大部分を失ってしまったらしく、その影響で火を嫌っている。火に関わる夢を見る対象へは近付きたがらず、妖精に巡回させている。"
        ]
      },
      {
        "title": "チャームカード",
        "body": [
          "夢符｢ポべートールの悪夢｣<br>悪符｢メアの金縛り｣<br>悪符｢ナイトメアワールド｣<br>夢符｢弾幕予知夢｣<br>夢符｢弾幕代償夢｣<br>神符｢モルペウスの神託｣<br>誘符｢眠り羊の数え唄｣<br>覚醒｢現世と夢現の境界線｣<br>刻符｢夢源の終焉｣<br>｢夢の案内人｣<br>｢胡蝶舞う夢幻世界｣"
        ]
      }
    ]
  },
